# 阶跃星辰 API Key（必填）
# 从 https://platform.stepfun.com 获取
STEPFUN_API_KEY=your_api_key_here

# 阶跃星辰 API 地址（无需修改）
STEPFUN_BASE_URL=https://api.stepfun.com/v1

# 视觉模型
VISION_MODEL=step-3.7-flash

# 语音识别模型（已由 realtime_handler 接管）
ASR_MODEL=stepaudio-2.5-asr

# 语音合成模型（已由 realtime_handler 接管）
TTS_MODEL=step-tts-mini

# 对话模型
CHAT_MODEL=step-3.7-flash

# 成本控制配置
MAX_FPS=1.0
MIN_FPS=0.2
SILENCE_THRESHOLD=500
MAX_TOKENS=4096
FRAME_RESIZE=512
JPEG_QUALITY=70
AUDIO_CHUNK_MS=3000
AUDIO_SAMPLE_RATE=24000

# 服务端口
PORT=8000
