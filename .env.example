# ── 默认 API 配置（图像和文本模型不单独配置时，共用此 Key）──
# 阶跃星辰 API Key（必填，ASR 语音识别依赖阶跃星辰）
# 从 https://platform.stepfun.com 获取
STEPFUN_API_KEY=your_api_key_here

# 阶跃星辰 API 地址（无需修改）
STEPFUN_BASE_URL=https://api.stepfun.com/v1

# ── 视觉模型（可选独立配置，不配则继承 STEPFUN）──
# 示例：使用硅基流动的 Qwen3-Omni 多模态模型
# VISION_MODEL=Qwen/Qwen3-Omni-30B-A3B-Instruct
# VISION_API_KEY=your_siliconflow_key
# VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=step-3.7-flash

# ── 语音识别模型 ──
ASR_MODEL=stepaudio-2.5-asr

# ── 语音合成模型（已禁用，由前端浏览器 TTS 接管）──
TTS_MODEL=step-tts-mini

# ── 对话模型（可选独立配置，不配则继承 STEPFUN）──
# 示例：使用硅基流动的 Qwen3-30B 模型
# CHAT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# CHAT_API_KEY=your_siliconflow_key
# CHAT_BASE_URL=https://api.siliconflow.cn/v1
CHAT_MODEL=step-3.7-flash

# ── 成本控制配置 ──
MAX_FPS=1.0
MIN_FPS=0.2
SILENCE_THRESHOLD=500
MAX_TOKENS=4096
FRAME_RESIZE=512
JPEG_QUALITY=70
AUDIO_CHUNK_MS=3000
AUDIO_SAMPLE_RATE=16000

# ── 服务端口 ──
PORT=8000